{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music OS",
  "version": "0.1.0",
  "identifier": "org.musicos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Music OS",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
